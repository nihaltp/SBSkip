def get_version_name_from_gradle
  gradle_file = File.expand_path("../app/build.gradle.kts", __dir__)
  unless File.exist?(gradle_file)
    raise "Could not find app/build.gradle.kts at #{gradle_file}"
  end
  content = File.read(gradle_file)
  if match = content.match(/^\s*versionName\s*=\s*"([^"]+)"/)
    return match[1]
  end
  raise "Could not find versionName in app/build.gradle.kts"
end

def get_version_code_from_gradle
  gradle_file = File.expand_path("../app/build.gradle.kts", __dir__)
  unless File.exist?(gradle_file)
    raise "Could not find app/build.gradle.kts at #{gradle_file}"
  end
  content = File.read(gradle_file)
  if match = content.match(/^\s*versionCode\s*=\s*(\d+)/)
    return match[1].to_i
  end
  raise "Could not find versionCode in app/build.gradle.kts"
end

def update_version_name(version_name:)
  gradle_file = File.expand_path("../app/build.gradle.kts", __dir__)
  unless File.exist?(gradle_file)
    raise "Could not find app/build.gradle.kts at #{gradle_file}"
  end
  content = File.read(gradle_file)
  updated_content = content.gsub(/^(\s*versionName\s*=\s*)"[^"]+"/, "\\1\"#{version_name}\"")
  File.write(gradle_file, updated_content)
end

def update_version_code(version_code:)
  gradle_file = File.expand_path("../app/build.gradle.kts", __dir__)
  unless File.exist?(gradle_file)
    raise "Could not find app/build.gradle.kts at #{gradle_file}"
  end
  content = File.read(gradle_file)
  updated_content = content.gsub(/^(\s*versionCode\s*=\s*)\d+/, "\\1#{version_code}")
  File.write(gradle_file, updated_content)
end

def resolve_abi_apk(device_id)
  device_abis = `adb -s #{device_id} shell getprop ro.product.cpu.abilist`.strip
  device_abis = `adb -s #{device_id} shell getprop ro.product.cpu.abi`.strip if device_abis.empty?

  primary_abi = device_abis.split(",").first.to_s.strip
  apk_name = case primary_abi
             when "arm64-v8a"
               "app-arm64-v8a-debug.apk"
             when "armeabi-v7a"
               "app-armeabi-v7a-debug.apk"
             when "x86_64"
               "app-x86_64-debug.apk"
             when "x86"
               "app-x86-debug.apk"
             else
               "app-universal-debug.apk"
             end

  split_apk = File.expand_path("../app/build/outputs/apk/debug/#{apk_name}", __dir__)
  universal_apk = File.expand_path("../app/build/outputs/apk/debug/app-universal-debug.apk", __dir__)

  File.exist?(split_apk) ? split_apk : universal_apk
end

default_platform(:android)

platform :android do
  desc "Increment patch version"
  lane :increment_patch do
    version = get_version_name_from_gradle
    version_parts = version.split(".").map(&:to_i)
    version_parts[2] += 1 # Increment patch version
    new_version = version_parts.join(".")
    update_version_name(version_name: new_version)
    increment_version_code # Also increment version code when patch version is updated
    puts "Version updated to #{new_version}"
  end

  desc "Increment minor version"
  lane :increment_minor do
    version = get_version_name_from_gradle
    version_parts = version.split(".").map(&:to_i)
    version_parts[1] += 1 # Increment minor version
    version_parts[2] = 0  # Reset patch version
    new_version = version_parts.join(".")
    update_version_name(version_name: new_version)
    increment_version_code # Also increment version code when minor version is updated
    puts "Version updated to #{new_version}"
  end

  desc "Increment major version"
  lane :increment_major do
    version = get_version_name_from_gradle
    version_parts = version.split(".").map(&:to_i)
    version_parts[0] += 1 # Increment major version
    version_parts[1] = 0  # Reset minor version
    version_parts[2] = 0  # Reset patch version
    new_version = version_parts.join(".")
    update_version_name(version_name: new_version)
    increment_version_code # Also increment version code when major version is updated
    puts "Version updated to #{new_version}"
  end

  desc "Increment version code"
  lane :increment_version_code do
    version_code = get_version_code_from_gradle
    new_version_code = version_code + 1 # Increment version code
    update_version_code(version_code: new_version_code)
    puts "Version code updated to #{new_version_code}"
  end

  desc "Print the current version name and code"
  lane :version do
    version_name = get_version_name_from_gradle
    version_code = get_version_code_from_gradle
    puts "Current version: #{version_name} (code: #{version_code})"
  end

  desc "Clean the project"
  lane :clean do
    gradle(task: "clean")
  end

  desc "Build the debug APK"
  lane :build_debug do
    gradle(task: "assembleDebug")
  end

  desc "Build the release APK"
  lane :build_release do
    gradle(task: "assembleRelease")
  end

  desc "Build release artifacts for GitHub Releases"
  lane :github_release do
    release
    sh("mkdir -p fastlane/output")
    sh("cp app/build/outputs/apk/release/*.apk fastlane/output/ 2>/dev/null || true")
  end

  desc "Run tests"
  lane :test do
    gradle(task: "test")
  end

  desc "Capture screenshots of the application using Screengrab"
  lane :screenshots do
    # Resolve device ID first
    properties = {}
    [File.expand_path("local.properties", __dir__), File.expand_path("../local.properties", __dir__)].each do |properties_path|
      next unless File.exist?(properties_path)

      File.readlines(properties_path).each do |line|
        next if line.strip.empty? || line.start_with?("#")
        key, value = line.strip.split("=", 2)
        properties[key] = value
      end

      break if properties["deviceId"] && !properties["deviceId"].strip.empty?
    end

    connected_devices = `adb devices`.scan(/^(\S+)\tdevice/).flatten
    preferred_device_ids = [properties["deviceId"], ENV["SCREENGRAB_SPECIFIC_DEVICE"]].compact.map { |device| device.strip }.reject(&:empty?)

    device_id = preferred_device_ids.find { |preferred_device_id| connected_devices.include?(preferred_device_id) }
    if device_id.nil? && preferred_device_ids.any?
      puts "Configured device is not connected; falling back to the first authorized adb device."
    end

    device_id ||= connected_devices.first

    raise "No active Android device found!" if device_id.nil? || device_id.strip.empty?
    puts "Using target device ID: #{device_id}"

    # Build the APKs
    gradle(task: "assembleDebug")
    gradle(task: "assembleDebugAndroidTest")

    # Uninstall existing packages to ensure a clean state
    puts "Uninstalling previous installations..."
    sh("adb -s #{device_id} uninstall com.nihaltp.sbskip.debug") rescue nil
    sh("adb -s #{device_id} uninstall com.nihaltp.sbskip.debug.test") rescue nil

    # Install both debug and test APKs
    puts "Installing debug and test APKs..."
    debug_apk = resolve_abi_apk(device_id)
    android_test_apk = File.expand_path("../app/build/outputs/apk/androidTest/debug/app-debug-androidTest.apk", __dir__)
    sh("adb -s #{device_id} install -r -t -g #{debug_apk}")
    sh("adb -s #{device_id} install -r -t -g #{android_test_apk}")

    # Clean previous screenshots on the device
    puts "Clearing previous screenshots on device..."
    sh("adb -s #{device_id} shell rm -rf /sdcard/Android/data/com.nihaltp.sbskip.debug/files/app_screengrab") rescue nil

    # Query original DND state (zen_mode)
    original_zen_mode = `adb -s #{device_id} shell settings get global zen_mode`.strip rescue "0"
    puts "Current system DND zen_mode is: #{original_zen_mode}"

    # Enable Do Not Disturb (zen_mode = 1) to block heads-up notifications
    puts "Enabling Do Not Disturb to suppress system notifications..."
    sh("adb -s #{device_id} shell settings put global zen_mode 1") rescue nil

    begin
      # Run the instrumented UI tests for locale en-US
      puts "Running instrumented tests..."
      sh("adb -s #{device_id} shell am instrument --no-window-animation -w -e testLocale en-US -e appendTimestamp false com.nihaltp.sbskip.debug.test/androidx.test.runner.AndroidJUnitRunner")

      # Pull screenshots directly from the app's external files directory on the device
      output_dir = "metadata/android/en-US/images/phoneScreenshots"
      require 'fileutils'
      FileUtils.mkdir_p(output_dir)
      # Clear local screenshots dir first to ensure we don't have old ones
      FileUtils.rm_rf(Dir.glob(File.join(output_dir, "*")))

      puts "Pulling screenshots manually from external storage..."
      sh("adb -s #{device_id} pull /sdcard/Android/data/com.nihaltp.sbskip.debug/files/app_screengrab/en-US/images/screenshots #{output_dir}")

      # Move files out of the nested folder if ADB nested them
      nested_dir = File.join(output_dir, "screenshots")
      if Dir.exist?(nested_dir)
        Dir.glob(File.join(nested_dir, "*")).each do |file|
          FileUtils.mv(file, output_dir, force: true)
        end
        FileUtils.rm_rf(nested_dir)
      end
      puts "Successfully pulled all screenshots manually to #{output_dir}!"
    ensure
      # Restore original DND setting precisely
      puts "Restoring original DND zen_mode state to: #{original_zen_mode}..."
      sh("adb -s #{device_id} shell settings put global zen_mode #{original_zen_mode}") rescue nil
    end
  end
end
